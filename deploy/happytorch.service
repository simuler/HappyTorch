[Unit]
Description=HappyTorch Web Service
After=network.target

[Service]
Type=simple
User=happytorch
Group=happytorch
WorkingDirectory=/home/github/HappyTorch
Environment=HOST=0.0.0.0
Environment=PORT=8000
Environment=HAPPYTORCH_DB_PATH=/srv/happytorch/data/happytorch.db
Environment=SESSION_COOKIE_SECURE=false
ExecStart=/usr/bin/python /home/github/HappyTorch/start_web.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
